    "self_load_triggers": [
      "got", "took", "loaded", "picked up", "self load", "self-load",
      "after hours", "loaded myself", "grabbed"
    ],
    "job_type_map": {
      "self_load":    ["got", "took", "loaded myself", "picked up", "after hours", "grabbed"],
      "delivered":    ["delivered", "deliver", "hauled", "brought", "dropped"],
      "fob":          ["fob", "picked up", "loaded out", "load out"],
      "spread_grade": ["spread", "grade", "graded", "grading", "leveled", "level"],
      "equipment":    ["machine", "excavator", "loader", "dozer", "hours", "equipment"],
      "site_work":    ["site", "house lot", "septic", "driveway", "pad", "install"]
