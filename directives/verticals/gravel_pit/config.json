{
  "vertical_key": "gravel_pit",
  "vertical_label": "Gravel Pit & Materials",
  "default_job_type": "delivered",
  "tax_rules": {
    "parts_rate": 0.055,
    "labor_rate": 0.0,
    "tax_label": "Maine 5.5%",
    "tax_on_delivery": true,
    "note": "Tax applies to product AND delivery charge combined. Labor/spread/grade is exempt."
