    "6_inch_minus",
    "bank_run_gravel",
    "loam",
    "crushed_stone",
    "rip_rap",
    "mulch",
    "crushed_gravel"
  ],
  "sms_keywords": {
    "invoice": [
      "delivered", "deliver", "hauled", "loaded", "got", "took",
      "picked up", "fob", "self load", "self-load", "yards", "yard",
      "ton", "tons", "sand", "gravel", "loam", "stone", "rip rap",
      "minus", "bank run", "spread", "grade", "graded", "hours", "labor"
    ],
    "proposal": [
      "need", "quote", "price", "how much", "deliver", "yards",
      "sand", "gravel", "loam", "stone", "minus", "bank run", "fill"
