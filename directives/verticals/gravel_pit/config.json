      "taxable": true,
      "unit": "yard",
      "description": "Product picked up at pit — price per yard"
    },
    "product_delivered": {
      "taxable": true,
      "unit": "yard",
      "description": "Product delivered — price per yard includes delivery"
    },
    "delivery_charge": {
      "taxable": true,
      "unit": "yard",
      "description": "Delivery charge — taxed as part of delivered price"
    },
    "spread_grade": {
      "taxable": false,
      "unit": "hour",
      "description": "Spread and grade labor — tax exempt"
    },
    "equipment": {
      "taxable": false,
      "unit": "hour",
      "description": "Equipment time — tax exempt"
    }
  },
  "products": [
    "sand",
    "bank_run_sand",
    "inch_minus",
    "2_inch_minus",
