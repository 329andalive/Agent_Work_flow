  },
  "field_keywords": [
    "yards", "yard", "ton", "tons", "sand", "gravel", "loam",
    "stone", "minus", "bank run", "rip rap", "mulch", "delivered",
    "fob", "spread", "grade", "loaded", "hauled", "got", "took"
  ],
  "job_type_regex": "deliver|fob|self.?load|spread|grade|excavat|site.?work",
  "taxable_keywords": [
    "sand", "gravel", "loam", "stone", "minus", "bank run",
    "rip rap", "mulch", "crushed", "fill", "material"
